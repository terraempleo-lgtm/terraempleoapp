{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(node -e \":*)",
      "Bash(node -c controllers/cognitoAuthController.js)",
      "Bash(node -c helpers/normalizePhone.js)",
      "Bash(node -c helpers/userSync.js)",
      "Bash(node -c scripts/auditUserPhones.js)",
      "Bash(node -c scripts/normalizeUserPhones.js)",
      "Bash(timeout 10 node -e \":*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Regex",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/vexp-guard.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
