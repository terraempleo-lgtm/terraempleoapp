# ─── Servidor ───
PORT=3000
NODE_ENV=

# ─── Base de datos (MariaDB / RDS) ───
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ─── SSL para base de datos ───
DB_SSL=
DB_SSL_CA_PATH=

# ─── JWT ───
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── AWS S3 ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ─── AWS Cognito (SMS / Auth) ───
COGNITO_REGION=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# ─── Email (recuperacion de password) ───
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ─── Admin seed (solo primera inicialización) ───
ADMIN_SEED_PASSWORD=

