{
  "expo": {
    "name": "TerraEmpleoApp",
    "slug": "TerraEmpleoApp",
    "owner": "rendonv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.terraempleo.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2E7D32",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.terraempleo.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/TerraEmpleo.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "f0c2d1e1-9208-44e1-af6f-9a2c29a3e5ba"
      }
    }
  }
}
