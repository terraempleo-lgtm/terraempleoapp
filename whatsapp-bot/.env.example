# ── Gateway WhatsApp (Evolution API + n8n) ──
# Copia a .env y rellena. NO commitear el .env real.

# apikey de Evolution API (la usará el backend de TerraEmpleo como WHATSAPP_API_KEY)
EVOLUTION_API_KEY=cambia-esta-clave-larga-y-secreta
# URL pública del gateway (en AWS: http://IP_O_DOMINIO:8080)
EVOLUTION_SERVER_URL=http://localhost:8080

# Contraseña del Postgres interno de Evolution
POSTGRES_PASSWORD=cambia-esta-password

# Webhook del backend TerraEmpleo donde Evolution entrega los mensajes entrantes.
# Debe ser accesible desde el gateway. Ej. producción:
#   https://api.terrampleo.com/api/webhooks/whatsapp?token=TU_WEBHOOK_TOKEN
# En desarrollo, con túnel (ngrok/cloudflared):
#   https://xxxx.ngrok-free.app/api/webhooks/whatsapp?token=TU_WEBHOOK_TOKEN
TERRAEMPLEO_WEBHOOK_URL=https://api.terrampleo.com/api/webhooks/whatsapp?token=cambia-este-token

# n8n (opcional)
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=cambia-esta-password
