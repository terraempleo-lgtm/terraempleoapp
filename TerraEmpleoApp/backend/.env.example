# ─── Servidor ───
PORT=3000
NODE_ENV=production

# ─── Base de datos (MariaDB / RDS) ───
DB_HOST=terraempleo-mariadb.xxxxx.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=terraempleoadmin
DB_PASSWORD=TU_PASSWORD_SEGURA
DB_NAME=terraempleo

# ─── SSL para RDS (producción) ───
# En local puedes omitir o poner DB_SSL=false
DB_SSL=true
DB_SSL_CA_PATH=/home/ubuntu/global-bundle.pem

# ─── JWT ───
JWT_SECRET=CAMBIA_ESTE_VALOR_POR_UNO_SEGURO
JWT_EXPIRES_IN=7d

# ─── AWS S3 ───
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=us-east-1
AWS_S3_BUCKET=terraempleo-prod-images

# ─── AWS Cognito (SMS / Auth) ───
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Email (recuperacion de password) ───
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-app-password
EMAIL_FROM=TerraEmpleo <tu-email@gmail.com>
