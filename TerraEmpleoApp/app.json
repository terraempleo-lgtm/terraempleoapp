{
  "expo": {
    "name": "TerraEmpleoApp",
    "slug": "TerraEmpleoApp",
    "owner": "rendonv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logos 2 TerraEmpleo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.terraempleo.app",
      "associatedDomains": ["webcredentials:app.terrampleo.com"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2E7D32",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.terraempleo.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_AUDIO",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD3jV2DMX9d4CPEC_vHcKgihsBDPt-sS1E"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/TerraEmpleo.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/TerraEmpleo.png",
          "color": "#2E7D32",
          "sounds": []
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "TerraEmpleo necesita acceso al micrófono para enviar notas de voz en el chat."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TerraEmpleo necesita acceso a tu ubicacion para mostrar vacantes cercanas."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f0c2d1e1-9208-44e1-af6f-9a2c29a3e5ba"
    },
    "extra": {
      "eas": {
        "projectId": "f0c2d1e1-9208-44e1-af6f-9a2c29a3e5ba"
      }
    }
  }
}
